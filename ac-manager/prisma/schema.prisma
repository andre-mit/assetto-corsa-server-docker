generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  password    String
  role        String   @default("VIEWER")
  createdAt   DateTime @default(now())
  createdById String?
  createdBy   User?    @relation("CreatedUsers", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdUsers User[]  @relation("CreatedUsers")
}

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  country     String?
  s3BadgeUrl  String?
  cars        Car[]
  createdAt   DateTime @default(now())
}

model Track {
  id          String   @id @default(cuid())
  folderName  String   @unique
  name        String
  pitboxes    Int
  country     String?
  s3ImageUrl  String?
  isMod       Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Car {
  id          String   @id @default(cuid())
  folderName  String   @unique
  name        String
  brand       String?
  brandRef    Brand?   @relation(fields: [brandId], references: [id])
  brandId     String?
  s3ImageUrl  String?
  isMod       Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ModJob {
  id        String   @id @default(cuid())
  type      String   // "UPLOAD" or "DOWNLOAD"
  target    String?  // URL or Filename
  status    String   // "PENDING", "DOWNLOADING", "EXTRACTING", "INGESTING", "SUCCESS", "FAILED"
  progress  Int      @default(0)
  error     String?
  result    Json?    // Stores the list of installed mods on success
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}